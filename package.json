{
    "name": "obsidian-sync-mcp",
    "version": "0.1.0",
    "description": "Remote MCP server that gives Claude access to your Obsidian vault via Self-hosted LiveSync and CouchDB",
    "type": "module",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/es617/obsidian-sync-mcp.git"
    },
    "keywords": ["mcp", "obsidian", "livesync", "couchdb", "claude", "ai"],
    "engines": {
        "node": ">=22"
    },
    "bin": {
        "obsidian-sync-mcp": "./dist/main.js"
    },
    "files": [
        "dist/",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "start": "node dist/main.js",
        "dev": "tsx src/main.ts"
    },
    "dependencies": {
        "diff-match-patch": "^1.0.5",
        "fastmcp": "^3.34.0",
        "fflate": "^0.8.2",
        "minimatch": "^9",
        "octagonal-wheels": "^0.1.39",
        "pouchdb-adapter-http": "^9.0.0",
        "pouchdb-core": "^9.0.0",
        "pouchdb-errors": "^9.0.0",
        "pouchdb-find": "^9.0.0",
        "pouchdb-mapreduce": "^9.0.0",
        "pouchdb-merge": "^9.0.0",
        "pouchdb-replication": "^9.0.0",
        "pouchdb-utils": "^9.0.0",
        "transform-pouch": "^2.0.0",
        "xxhash-wasm": "^1.0.2",
        "zod": "^3"
    },
    "devDependencies": {
        "@types/node": "^22",
        "tsup": "^8",
        "tsx": "^4",
        "typescript": "^5"
    }
}

# Required
COUCHDB_PASSWORD=<generate-a-strong-password>
MCP_AUTH_TOKEN=<generate-a-strong-password>
VAULT_NAME=MyVault

# LiveSync user (recommended — limited permissions for sync)
LIVESYNC_USER=livesync
LIVESYNC_PASSWORD=<generate-a-strong-password>

# E2E encryption (only if enabled in LiveSync plugin)
# COUCHDB_PASSPHRASE=your-passphrase

# Defaults (usually don't need to change)
# COUCHDB_USER=admin
# COUCHDB_DATABASE=obsidian
